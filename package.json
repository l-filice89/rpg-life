{
  "name": "rpg-life",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "clean": "rm -rf node_modules .turbo && turbo clean",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "db:studio": "turbo db:studio",
    "smoke": "bun test apps/api/tests/scaffold.test.ts packages/db/src/schema.test.ts packages/db/src/__tests__/quest-schema.test.ts packages/api/src/__tests__/tasks-list.test.ts packages/api/src/__tests__/tasks-create.test.ts packages/api/src/__tests__/tasks-update.test.ts packages/api/src/__tests__/tasks-delete.test.ts packages/api/src/__tests__/profile-get.test.ts"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "eslint-plugin-boundaries": "^4.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "~5.6.0"
  },
  "packageManager": "bun@1.3.8",
  "dependencies": {
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
