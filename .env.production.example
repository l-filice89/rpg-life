# =============================================================================
# rpg-life — Production Environment Variables
# =============================================================================
# Copy these into your hosting provider (Railway, Vercel, etc.).
# =============================================================================

# --- Database (SQLite file path inside the api container) ---
DATABASE_URL=file:/data/rpg-life.db

# --- Authentication ---
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://app.yourdomain.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://app.yourdomain.com

# --- Email (Resend magic link) ---
RESEND_API_KEY=
EMAIL_FROM=auth@yourdomain.com

# --- App URLs ---
WEB_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com

# --- Runtime ---
NODE_ENV=production
PORT=3002
