# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local dev (root .env/.env.local): API runs from apps/api, so use repo-root data:
DATABASE_URL=file:../../data/rpg-life.db
# Docker compose runtime path:
# DATABASE_URL=file:/data/rpg-life.db

# -----------------------------------------------------------------------------
# Authentication (better-auth)
# -----------------------------------------------------------------------------
# 32+ random characters used to sign/verify auth tokens.
# Generate one: `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-to-a-32-plus-character-secret
# Public web URL used for auth links + cookie scope.
BETTER_AUTH_URL=http://localhost:3000
# Client-side mirror for better-auth browser usage.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email delivery (Resend)
# -----------------------------------------------------------------------------
# Get from https://resend.com/api-keys (format: re_xxx).
RESEND_API_KEY=re_your_key_here
# Sender identity verified in Resend (sandbox can use onboarding@resend.dev).
EMAIL_FROM=onboarding@resend.dev

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
# API URL used by web SSR/rewrite targets in local development.
API_URL=http://localhost:3002
# Public web origin used by API for CORS + redirect allow-lists.
WEB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
# API port used by apps/api start.ts fallback (docker-compose hardcodes PORT: 3002
# directly and does NOT interpolate this value — changing it here won't affect Docker).
PORT=3002
# API port consumed by apps/api/src/lib/env.ts and the root dev orchestration script.
PORT_API=3002
# Web dev server port used by apps/web scripts.
PORT_WEB=3000

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
# Use `development` for local, `production` in docker/prod deployments.
# WARNING: `test` enables the POST /api/auth/test-session bypass endpoint for E2E
# testing — never use `test` in production or any publicly reachable environment.
NODE_ENV=development
