# Database (api only) — local dev uses repo-root ./data volume path
DATABASE_URL=file:../../data/rpg-life.db
# Docker: DATABASE_URL=file:/data/rpg-life.db

# better-auth
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# Email (Resend — required; magic-link auth fails fast without these)
RESEND_API_KEY=
EMAIL_FROM=

# Next.js → api proxy. Local dev targets localhost; docker compose passes
# http://api:3002 as a build arg automatically (see docker-compose.yml).
API_URL=http://localhost:3002

# App ports
PORT_WEB=3000
PORT_API=3002
WEB_URL=http://localhost:3000
NODE_ENV=development
