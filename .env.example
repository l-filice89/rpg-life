# Database (api only) — local dev uses repo-root ./data volume path
DATABASE_URL=file:../../data/rpg-life.db
# Docker: DATABASE_URL=file:/data/rpg-life.db

# better-auth (api + browser client — keep these in sync)
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Email (Resend — required; magic-link auth fails fast without these)
# Placeholder only; use your own key (example format: re_xxxxxxxxxxxxx)
RESEND_API_KEY=re_placeholder_replace_me
# Dev: onboarding@resend.dev (only delivers to your Resend account email until you verify a domain)
EMAIL_FROM=onboarding@resend.dev

# Next.js → api proxy. Local dev targets localhost; docker compose passes
# http://api:3002 as a build arg automatically (see docker-compose.yml).
API_URL=http://localhost:3002

# App ports
PORT_WEB=3000
PORT_API=3002
# Public web origin for auth redirects + API CORS allow-list.
WEB_URL=http://localhost:3000
NODE_ENV=development
