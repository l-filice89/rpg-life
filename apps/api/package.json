{
  "name": "@rpg-life/server",
  "version": "0.0.0",
  "private": true,
  "main": "./src/app.ts",
  "exports": {
    ".": "./src/app.ts"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@rpg-life/api": "workspace:*",
    "@rpg-life/auth": "workspace:*",
    "@rpg-life/db": "workspace:*",
    "@t3-oss/env-core": "^0.12.0",
    "hono": "^4.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --env-file=../../.env.local --watch src/start.ts",
    "build": "bun build src/start.ts --outdir dist --target bun",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "bun test tests/",
    "start": "bun run src/start.ts"
  }
}
