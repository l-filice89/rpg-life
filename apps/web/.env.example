# API Server URL (server-side, used by auth & tRPC proxy routes)
API_URL=http://localhost:3002

# API Server URL (client-side, used by tRPC client — proxied via /trpc/*)
NEXT_PUBLIC_API_URL=http://localhost:3002

# better-auth browser client (must match BETTER_AUTH_URL on api)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
